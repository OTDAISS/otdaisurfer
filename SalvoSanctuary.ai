    <div class="absolute inset-0 opacity-30 pointer-events-none">
        <div class="absolute top-1/4 left-1/2 w-[600px] h-[600px] bg-orange-500 rounded-full filter blur-[120px] animate-pulse"></div>
        <div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-teal-500 rounded-full filter blur-[100px]"></div>
    </div>

    <div class="max-w-4xl mx-auto relative z-10">
        <!-- Memorial Header: Johnny Bull Hooper -->
