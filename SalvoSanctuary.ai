            <span class="text-cyan-400 font-bold tracking-[0.3em] uppercase text-xs mb-4 block">Special Dedication: Salvo Sanctuary</span>
            <h1 class="text-6xl md:text-8xl font-black text-white uppercase tracking-tighter mb-4 italic">Johnny Bull Hooper</h1>
            <p class="text-xl text-slate-400 italic">"Riding the Eternal Swell at Cape Point"</p>
        </div>

        <!-- The Respects Barrel: Posting Interface [5, 6] -->
        <div class="glass p-1 rounded-[2.5rem] mb-12 shadow-[0_0_50px_rgba(34,211,238,0.1)]">
            <div class="bg-slate-900/80 rounded-[2.4rem] p-10">
                <h3 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
                    <i class="fa-solid fa-water text-cyan-400"></i> Drop-In Your Respects
                </h3>
                <form id="respects-form" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <input type="text" placeholder="Your Name / Local Break" class="bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-cyan-500 transition w-full">
                        <input type="text" placeholder="Favorite Johnny Bull Story" class="bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-cyan-500 transition w-full">
                    </div>
                    <textarea rows="4" placeholder="Post your tribute to the legend..." class="bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-cyan-500 transition w-full"></textarea>
                    
                    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
                        <div class="text-xs text-slate-500 font-bold uppercase tracking-widest">
                            <i class="fa-solid fa-microphone text-cyan-400 mr-2"></i> Voice Enabled via Sea Mist Orb [7]
                        </div>
                        <button type="submit" class="bg-cyan-500 text-slate-900 px-12 py-4 rounded-full font-black uppercase hover:bg-cyan-400 hover:scale-105 transition shadow-lg shadow-cyan-500/20">
                            POST TO THE BARREL
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- The Heritage Archive: Infinite Scroll Feed [8, 9] -->
        <div class="space-y-8" id="respects-feed">
            <h4 class="text-sm font-black text-slate-500 uppercase tracking-[0.4em] mb-8 text-center">Community Tribute Stream</h4>
            
            <!-- Example Respect Post [6] -->
            <div class="glass p-8 rounded-[2rem] border-l-4 border-cyan-500 hover:bg-white/5 transition group">
                <div class="flex justify-between items-start mb-4">
                    <div>
                        <h5 class="text-white font-bold text-lg">Hatteras Local</h5>
                        <p class="text-cyan-500 text-xs font-bold uppercase tracking-widest">March 25, 2026</p>
                    </div>
                    <i class="fa-solid fa-bell text-slate-600 group-hover:text-cyan-400 transition"></i> <!-- Bell Icon Notification [6] -->
                </div>
                <p class="text-slate-300 leading-relaxed italic">"Johnny Bull always knew when the swell was hitting the Shoals before the reports even came out. A true island legend who shaped the spirit of Salvo."</p>
            </div>

            <!-- More posts load via Infinite Scroll [8] -->
        </div>
    </div>
</section>
